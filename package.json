{
    "name": "oyen",
    "version": "1.0.0",
    "description": "A lightweight desktop code editor with an integrated terminal, file tools, and remote SFTP/FTP support.",
    "main": "src/main/index.js",
    "scripts": {
        "start": "electron .",
        "predev": "node scripts/free-port.mjs 5173",
        "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
        "dev:renderer": "vite --config vite.renderer.config.mjs",
        "dev:electron": "wait-on tcp:5173 && cross-env OYEN_DEV_SERVER_URL=http://127.0.0.1:5173 nodemon --watch src/main --watch src/preload --ext js --exec \"electron .\"",
        "rebuild": "electron-rebuild -f -w @homebridge/node-pty-prebuilt-multiarch",
        "icon": "node scripts/make-icon.mjs",
        "build:renderer": "vite build --config vite.renderer.config.mjs",
        "dist": "npm run build:renderer && electron-builder",
        "postinstall": "node scripts/postinstall.mjs"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/llack/oyen.git"
    },
    "keywords": [],
    "author": "",
    "license": "MIT",
    "type": "commonjs",
    "bugs": {
        "url": "https://github.com/llack/oyen/issues"
    },
    "homepage": "https://github.com/llack/oyen#readme",
    "devDependencies": {
        "@electron/rebuild": "^3.7.0",
        "@resvg/resvg-js": "^2.6.2",
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "electron": "^42.0.1",
        "electron-builder": "^26.15.2",
        "electronmon": "^2.0.4",
        "nodemon": "^3.1.14",
        "vite": "^8.0.12",
        "wait-on": "^9.0.7"
    },
    "nodemonConfig": {
        "delay": 150,
        "signal": "SIGTERM"
    },
    "build": {
        "appId": "com.oyen.editor",
        "productName": "Oyen",
        "directories": { "output": "release", "buildResources": "build" },
        "files": [
            "src/main/**/*",
            "src/preload/**/*",
            "src/renderer/dist/**/*",
            "package.json"
        ],
        "asarUnpack": ["**/node_modules/@homebridge/node-pty-prebuilt-multiarch/**"],
        "protocols": [{ "name": "Oyen Quick Open", "schemes": ["oyen-quick"] }],
        "win": { "target": ["nsis", "portable"] },
        "mac": { "target": ["dmg"], "category": "public.app-category.developer-tools" },
        "linux": { "target": ["AppImage"] }
    },
    "dependencies": {
        "@codemirror/autocomplete": "^6.20.2",
        "@codemirror/commands": "^6.10.3",
        "@codemirror/lang-css": "^6.3.1",
        "@codemirror/lang-html": "^6.4.11",
        "@codemirror/lang-javascript": "^6.2.5",
        "@codemirror/lang-json": "^6.0.2",
        "@codemirror/lang-markdown": "^6.5.0",
        "@codemirror/lang-php": "^6.0.2",
        "@codemirror/lang-python": "^6.2.1",
        "@codemirror/lang-sql": "^6.10.0",
        "@codemirror/lang-xml": "^6.1.0",
        "@codemirror/lang-yaml": "^6.1.3",
        "@codemirror/legacy-modes": "^6.5.3",
        "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
        "@lezer/highlight": "^1.2.3",
        "@replit/codemirror-minimap": "^0.5.2",
        "@tabler/icons": "^3.44.0",
        "@vscode/codicons": "^0.0.45",
        "@xterm/addon-fit": "^0.10.0",
        "@xterm/addon-web-links": "^0.11.0",
        "@xterm/xterm": "^5.5.0",
        "basic-ftp": "^6.0.1",
        "codemirror": "^6.0.2",
        "github-markdown-css": "^5.9.0",
        "iconv-lite": "^0.7.2",
        "jschardet": "^3.1.4",
        "lucide": "^1.14.0",
        "markdown-it": "^14.1.1",
        "simple-git": "^3.36.0",
        "ssh2": "^1.17.0"
    }
}
